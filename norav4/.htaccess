<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase "/ppl - Copy (2)/nora2.0/norav4/"
    
    # 1. Direct access to static assets in public folder
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_URI} ^/(assets|css|js|images|vendor)/
    RewriteRule ^(.*)$ public/$1 [L]

    # 2. Map 'office' to login directly for convenience
    RewriteRule ^office/?$ public/index.php?gate=login [L,QSA]
    
    # 3. Prevent infinite loops if already in public
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^public/ - [L]
    
    # 4. Handle Root Access (empty path) -> Home
    RewriteRule ^$ public/index.php?gate=home [L,QSA]
    
    # 5. Handle direct index.php calls by passing through to public
    RewriteRule ^index\.php$ public/index.php [L,QSA]
    
    # 6. Redirect everything else to public folder index
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/index.php?gate=$1 [L,QSA]
</IfModule>

# Security: Prevent directory listing at root level
Options -Indexes

# Error handling
ErrorDocument 403 /public/index.php?gate=home
ErrorDocument 404 /public/index.php?gate=home
