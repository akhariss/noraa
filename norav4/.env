
# norav4 Environment Configuration
# Copy to .env and edit for production/shared hosting

APP_ENV=production
APP_NAME="Notaris Sri Anah SH.M.Kn"
APP_VERSION="4.0.0"

# Database (MySQL/MariaDB)
DB_HOST=localhost
DB_NAME=norav4
DB_USER=root
DB_PASS=

# Security Keys (generate random, change in production!)
SECURITY_KEY_ID=your_random_key_32_chars_here
SECURITY_KEY_IMG=your_img_encrypt_key_here
SECURITY_KEY_TRACKING=your_tracking_key_here
SECURITY_KEY_SHORT=your_short_key_here

# Optional: Manual APP_URL if auto-detect fails
# APP_URL=http://yourdomain.com/norav4

